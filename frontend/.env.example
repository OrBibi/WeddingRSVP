# Local admin API (dashboard + local tooling)
VITE_API_URL=http://localhost:3001/api

# Public RSVP API base.
# Local development default can stay on local backend.
# In Vercel RSVP deployment use: /api/public
VITE_PUBLIC_RSVP_API_URL=http://localhost:3001/api/public

# Public RSVP site URL used for generating invite links from local dashboard
VITE_PUBLIC_RSVP_SITE_URL=https://your-rsvp-vercel-domain.vercel.app

# Firebase web app settings (used by local admin frontend auth flow)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

