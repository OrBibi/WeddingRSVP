PORT=3001
DEFAULT_WEDDING_ID=my-wedding

# Use compact RSVP URLs in WhatsApp (/r/.../slug). Set to false to always send the long /rsvp/.../guestId link.
RSVP_SHORT_LINKS=

# Firebase Admin (preferred single var)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative Firebase Admin vars
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# WhatsApp send pacing (milliseconds)
WA_DELAY_MIN_MS=2000
WA_DELAY_MAX_MS=7000
